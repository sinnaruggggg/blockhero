{
  "name": "blockhero-creator-desktop",
  "version": "1.3.83",
  "description": "Desktop editor for BlockHero creator content.",
  "author": "OpenAI Codex",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dist": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.blockhero.creator.desktop",
    "productName": "BlockHero Creator",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "bundled-platform-tools",
        "to": "platform-tools"
      }
    ],
    "files": [
      "main.js",
      "desktop-preload.js",
      "app/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
